# BlueprintParser Deployment Configuration
# Copy this file to .deploy.env and fill in your values:
#   cp .deploy.env.example .deploy.env
#
# .deploy.env is gitignored and will not be committed.

AWS_ACCOUNT=YOUR_12_DIGIT_ACCOUNT_ID
AWS_REGION=us-east-1

# ECS
ECS_CLUSTER=beaver-cluster
ECS_SERVICE=beaver-app

# ECR
ECR_REPO=beaver-app
ECR_YOLO_REPO=beaver-yolo-pipeline

# Monitoring / Health Checks
ALB_NAME=beaver-alb
RDS_ID=beaver-db
LOG_GROUP=/ecs/beaver-app
SNS_TOPIC=beaver-alerts

# Domain (used in Label Studio setup and deploy scripts)
DOMAIN=yourdomain.com

# Secrets Manager prefix
SECRETS_PREFIX=beaver

###############################################################################
# Beaver Infrastructure - ECR Repositories
###############################################################################

resource "aws_ecr_repository" "beaver_app" {
  name                 = "beaver-app"
  image_tag_mutability = "MUTABLE"
  force_delete         = false

  image_scanning_configuration {
    scan_on_push = true
  }

  encryption_configuration {
    encryption_type = "AES256"
  }

  tags = {
    Name = "beaver-app"
  }
}


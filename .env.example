DATABASE_URL=postgresql://user:password@host:5432/dbname
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=https://app.blueprintparser.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=beaver-data-ACCOUNT_ID
CLOUDFRONT_DOMAIN=assets.blueprintparser.com
STEP_FUNCTION_ARN=arn:aws:states:us-east-1:ACCOUNT_ID:stateMachine:beaver-process-blueprint
PROCESSING_WEBHOOK_SECRET=generate-a-random-secret
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...

# LLM Config encryption key (for storing API keys in DB)
# Falls back to NEXTAUTH_SECRET if not set
LLM_KEY_SECRET=generate-a-random-32-char-secret

# Override LLM provider via env (alternative to admin UI config)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=http://localhost:11434/v1

# Label Studio (data labeling integration — optional)
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=
LABEL_STUDIO_ADMIN_EMAIL=admin@blueprintparser.local
LABEL_STUDIO_ADMIN_PASSWORD=changeme123

DATABASE_URL=postgresql://beaver:beaver@localhost:5433/beaverdb
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=your-s3-bucket-name
NEXT_PUBLIC_S3_BUCKET=your-s3-bucket-name
CLOUDFRONT_DOMAIN=
STEP_FUNCTION_ARN=
PROCESSING_WEBHOOK_SECRET=generate-a-random-secret
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...

# LLM Config encryption key (for storing API keys in DB)
# Falls back to NEXTAUTH_SECRET if not set
LLM_KEY_SECRET=generate-a-random-32-char-secret

# Override LLM provider via env (alternative to admin UI config)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=http://localhost:11434/v1

# Label Studio (data labeling integration — optional)
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=
LABEL_STUDIO_ADMIN_EMAIL=admin@localhost.local
LABEL_STUDIO_ADMIN_PASSWORD=changeme123

# Optional: YOLO/SageMaker (GPU object detection)
# YOLO_ECR_IMAGE=ACCOUNT.dkr.ecr.REGION.amazonaws.com/your-yolo-image:latest
# SAGEMAKER_ROLE_ARN=arn:aws:iam::ACCOUNT:role/your-sagemaker-role

# Optional: SES Email (password recovery)
# SES_FROM_EMAIL=noreply@yourdomain.com

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Root admin bootstrap (first user with this email gets root admin on login)
# ROOT_ADMIN_EMAIL=admin@yourdomain.com
